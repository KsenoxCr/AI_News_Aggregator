@startuml
left to right direction
skinparam packageStyle rectangle

actor "Käyttäjä" as User
actor "Ylläpitäjä" as Admin
actor "Järjestelmä" as System
actor "Tekoälymalli (LLM)" as LLM
actor "Uutislähde (RSS/Feed)" as Feed

rectangle "Uutisten kerääjä" {

  ' Auth
  usecase "UC01: Kirjaudu sisään (magic link)" as UC01
  usecase "UC02: Pyydä magic link sähköpostiin" as UC02
  usecase "UC03: Validoi magic link token" as UC03

  ' Settings
  usecase "UC04: Hallitse asetuksia" as UC04
  usecase "UC05: Valitse uutislähteet" as UC05
  usecase "UC06: Lisää oma uutislähde" as UC06
  usecase "UC07: Valitse tekoälymalli" as UC07
  usecase "UC08: Aseta API avain" as UC08
  usecase "UC09: Poista API avain" as UC09
  usecase "UC10: Aseta mieltymykset" as UC10

  ' News browsing
  usecase "UC11: Selaa uutisotsikkoja" as UC11
  usecase "UC12: Suodata uutisia aikavälille ja/tai teemoihin" as UC12
  usecase "UC13: Lue uutistiivistelmä" as UC13
  usecase "UC14: Avaa alkuperäinen artikkeli" as UC14

  ' System / background
  usecase "UC15: Hae uutiset lähteistä" as UC15
  usecase "UC16: Suodata ja kategorisoi uutiset LLM:llä" as UC16
  usecase "UC17: Deduplikoi uutiset" as UC17
  usecase "UC18: Näytä virheviesti" as UC18

  ' Admin
  usecase "UC19: Hallitse valmiita uutislähteitä" as UC19
  usecase "UC20: Hallitse ilmaista API avainta" as UC20
}

' User flows
User --> UC01
UC01 ..> UC02 : <<include>>
UC01 ..> UC03 : <<include>>

User --> UC04
UC04 ..> UC05 : <<include>>
UC04 ..> UC07 : <<include>>
UC04 ..> UC10 : <<include>>
UC05 ..> UC06 : <<extend>>
UC07 ..> UC08 : <<extend>>
UC08 ..> UC09 : <<extend>>

User --> UC11
UC11 ..> UC12 : <<extend>>
UC11 ..> UC15 : <<include>>
UC15 ..> UC16 : <<include>>
UC16 ..> UC17 : <<include>>

User --> UC13
UC13 ..> UC14 : <<extend>>

UC03 --> System
UC15 --> Feed
UC16 --> LLM


UC06 ..> UC18 : <<extend>>
UC13 ..> UC18 : <<extend>>
UC15 ..> UC18 : <<extend>>
UC16 ..> UC18 : <<extend>>
UC03 ..> UC18 : <<extend>>

Admin --> UC01
Admin --> UC19
Admin --> UC20
@enduml
