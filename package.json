{
  "name": "ai_news_aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "dev": "next dev --turbo",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "diagram": "npx sql2dbml ./src/server/db/schema.sql --mysql | npx dbml-renderer -o ./docs/diagrams/er-diagram.svg",
    "db:start": "./scripts/start-db.sh",
    "db:gen-if": "./scripts/gen-db-if.sh"
  },
  "dependencies": {
    "@react-email/components": "^1.0.9",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.3",
    "kysely": "^0.28.12",
    "mysql2": "^3.20.0",
    "next": "^15.2.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "superjson": "^2.2.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@dbml/cli": "^6.4.0",
    "@softwaretechnik/dbml-renderer": "^1.0.31",
    "@tailwindcss/postcss": "^4.0.15",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "kysely-codegen": "^0.20.0",
    "postcss": "^8.5.3",
    "sql-lint": "^1.0.2",
    "tailwindcss": "^4.0.15",
    "typescript": "^5.8.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "npm@11.11.0"
}
