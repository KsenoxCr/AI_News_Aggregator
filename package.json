{
  "name": "ai_news_aggregator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "biome check .",
    "check:unsafe": "biome check --write --unsafe .",
    "check:write": "biome check --write .",
    "dev": "next dev --turbo",
    "preview": "next build && next start",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:diagram": "pnpm dlx sql2dbml ./src/server/db/schema.sql --mysql | npx dbml-renderer -o ./docs/diagrams/er-diagram.svg",
    "db:start": "./scripts/start-db.sh",
    "db:gen-if": "./scripts/gen-db-if.sh",
    "db:migrate": "kysely migrate latest",
    "db:rollback": "kysely migrate rollback --all",
    "db:make": "kysely migrate make",
    "db:status": "kysely migrate list",
    "db:migrate-codegen": "./scripts/migration_with_codegen.sh",
    "db:seed": "pnpm tsx ./scripts/seed.ts"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.6",
    "@react-email/components": "^1.0.9",
    "@t3-oss/env-nextjs": "^0.12.0",
    "@tanstack/react-query": "^5.69.0",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "better-auth": "^1.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.12",
    "mysql2": "^3.20.0",
    "next": "^16.2.1",
    "next-intl": "^4.8.3",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "resend": "^6.9.4",
    "rss-parser": "^3.13.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "superjson": "^2.2.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "zod": "^3.24.2",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.5",
    "@dbml/cli": "^6.4.0",
    "@fsouza/prettierd": "^0.27.0",
    "@softwaretechnik/dbml-renderer": "^1.0.31",
    "@tailwindcss/postcss": "^4.0.15",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@types/node": "^20.14.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "kysely-codegen": "^0.20.0",
    "kysely-ctl": "^0.20.0",
    "postcss": "^8.5.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sql-lint": "^1.0.2",
    "tailwindcss": "^4.0.15",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.40.0"
  },
  "packageManager": "pnpm@10.33.0"
}
